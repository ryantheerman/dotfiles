# output entire history
alias history="history 0"

### TMUX INSTANCES ###
alias mux='tmux.sh'

# console output color
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# output usage stats for the drives I care about
alias dfx='df -H -x tmpfs -x efivarfs'

# sudo with environment configs
alias sudo='sudo -E'

# wolf docker container
alias wolf='wolf.sh'
